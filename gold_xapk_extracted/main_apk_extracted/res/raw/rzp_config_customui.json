  "static_rules": {
    "identify_network": {
      "visa": "^4",
      "mastercard": "^(5[1-5]|2[2-7])",
      "maestro16": "^50(81(25|26|59|92)|8227)|4(437|681)",
      "amex": "^3[47]",
      "rupay": "^(508[5-9]|60(80(0|)[^0]|8[1-4]|8500|698[5-9]|699|7[^9]|79[0-7]|798[0-4])|65(2(1[5-9]|[2-9])|30|31[0-4])|817[2-9]|81[89]|820[01])",
      "discover": "^(65[1,3-9]|6011)",
      "maestro": "^(6|5(0|[6-9])).{5}",
      "diners": "^3[0689]",
      "jcb": "^35"
    },
    "network_card_length": {
